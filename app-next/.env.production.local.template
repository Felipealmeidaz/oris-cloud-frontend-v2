# ============================================================
# Template pra config das env vars Vercel via REST API
# ============================================================
# INSTRUCOES:
# 1. Copie este arquivo pra .env.production.local (mesma pasta)
#    PowerShell: Copy-Item .env.production.local.template .env.production.local
# 2. Preencha os VALORES sensiveis nas linhas abaixo
# 3. Avise no chat que terminou
# 4. Eu leio este arquivo (nunca aparece no chat) e pushed via API Vercel
# 5. Depois pode deletar o arquivo local (ele ja esta no .gitignore via .env*)
# ============================================================

# --- Database (Railway Postgres) -----------------------------
# Pegar no Railway: Dashboard -> Postgres -> Variables -> DATABASE_URL
# Formato esperado: postgresql://postgres:PASS@HOST.railway.internal:5432/railway
DATABASE_URL=

# --- better-auth ---------------------------------------------
# GERAR novo secret: Cascade pode gerar com openssl rand -base64 32
# (deixe vazio e eu gero automaticamente no script)
BETTER_AUTH_SECRET=

# URL publica (dominio Vercel atual ou custom domain futuro)
# Ex: https://oris-cloud-frontend.vercel.app
BETTER_AUTH_URL=https://oris-cloud-frontend.vercel.app
NEXT_PUBLIC_BETTER_AUTH_URL=https://oris-cloud-frontend.vercel.app
NEXT_PUBLIC_URL=https://oris-cloud-frontend.vercel.app

# --- Resend (emails) -----------------------------------------
# Pegar em resend.com/api-keys (voce ja tem 2 keys criadas hoje)
# Formato: re_...
RESEND_API_KEY=

# Em dev sem domain verificado: onboarding@resend.dev
# Em prod com dominio verificado no Resend: noreply@oriscloud.com.br
RESEND_FROM_EMAIL=onboarding@resend.dev

# --- AWS (provisioning de VMs EC2) ---------------------------
AWS_REGION=sa-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_AMI_ID=
AWS_VPC_ID=
AWS_SUBNET_ID=
AWS_SECURITY_GROUP_ID=
AWS_KEY_PAIR_NAME=oris-keypair
AWS_INSTANCE_TYPE=g4dn.xlarge
AWS_AVAILABILITY_ZONE=sa-east-1a

# --- Sunshine (streaming server na VM) -----------------------
# Configurar conforme a AMI Windows Server com Sunshine instalado
SUNSHINE_USER=oris
SUNSHINE_PASS=

# --- EfiBank PIX ---------------------------------------------
# Se ainda nao tem EfiBank configurado, deixe vazio - endpoint de pagamento
# vai retornar erro mas o resto do app funciona
EFI_CLIENT_ID=
EFI_CLIENT_SECRET=
EFI_PIX=
# PEMs multilinha - colar conteudo inteiro entre aspas, incluindo BEGIN/END
# Exemplo: EFI_CERT_PEM="-----BEGIN CERTIFICATE-----\nMIIE...\n-----END CERTIFICATE-----"
EFI_CERT_PEM=
EFI_KEY_PEM=
EFI_CA_PEM=

# --- Discord (opcional, pode deixar vazio por enquanto) ------
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_ROLE_ID=
DISCORD_WEBHOOK_URL=

# --- Seguranca interna ---------------------------------------
# Deixe vazio - eu gero automaticamente no script
INTERNAL_WEBHOOK_SECRET=

# --- Node ----------------------------------------------------
NODE_ENV=production
