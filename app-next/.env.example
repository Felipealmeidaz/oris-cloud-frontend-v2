# ============================================================
# Oris Cloud - Variaveis de Ambiente
# ============================================================
# Todas as variaveis marcadas [REQUIRED] precisam estar setadas
# no Vercel (Settings -> Environment Variables) antes do deploy.
# ============================================================

# --- Database (Railway Postgres) -----------------------------
# [REQUIRED] Connection string completa do Postgres.
# Ex: postgresql://postgres:PASS@HOST.railway.internal:5432/railway
DATABASE_URL=postgresql://user:password@localhost:5432/oris_cloud

# --- better-auth ---------------------------------------------
# [REQUIRED] Secret pra assinar cookies/JWTs. Gerar com:
#   openssl rand -base64 32
BETTER_AUTH_SECRET=your-secret-generate-with-openssl-rand-base64-32

# [REQUIRED] URL publica do app em prod (usada nos links de email).
# Em desenvolvimento: http://localhost:3000
# Em producao: https://oriscloud.com.br (ou dominio Vercel)
BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000
NEXT_PUBLIC_URL=http://localhost:3000

# --- Resend (emails transacionais) ---------------------------
# [REQUIRED para prod] Chave API do Resend (dashboard resend.com)
RESEND_API_KEY=re_your_resend_api_key_here

# [REQUIRED para prod] Email remetente verificado no Resend.
# Em dev sem domain verificado: onboarding@resend.dev
# Em prod com domain: noreply@oriscloud.com.br
RESEND_FROM_EMAIL=onboarding@resend.dev

# --- AWS (provisioning de VMs EC2) ---------------------------
# [REQUIRED para prod] Credenciais AWS. Em producao, preferir IAM Role
# anexada ao servico; access keys apenas em dev/local.
AWS_REGION=sa-east-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key

# [REQUIRED para prod] Recursos AWS pra criar instancias EC2.
AWS_AMI_ID=ami-xxxxxxxxxxxxxxxxx
AWS_VPC_ID=vpc-xxxxxxxxxxxxxxxxx
AWS_SUBNET_ID=subnet-xxxxxxxxxxxxxxxxx
AWS_SECURITY_GROUP_ID=sg-xxxxxxxxxxxxxxxxx
AWS_KEY_PAIR_NAME=oris-keypair
AWS_INSTANCE_TYPE=g4dn.xlarge
AWS_AVAILABILITY_ZONE=sa-east-1a

# --- Sunshine (streaming server na VM) -----------------------
# [REQUIRED para prod] Basic auth pra API do Sunshine que roda na VM.
# Configurar conforme a AMI - NAO usar credencial default em prod.
SUNSHINE_USER=oris
SUNSHINE_PASS=change-me-strong-random-password

# --- EfiBank/EfiPay PIX --------------------------------------
# [REQUIRED para prod] Integracao de pagamento PIX via Efi.
EFI_CLIENT_ID=your-client-id
EFI_CLIENT_SECRET=your-client-secret
EFI_CERT_PEM=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
EFI_KEY_PEM=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
EFI_CA_PEM=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
EFI_PIX=your-pix-key

# --- Discord Bot ---------------------------------------------
# [OPCIONAL] Integracao com Discord (bot, roles, webhook de notificacoes)
DISCORD_BOT_TOKEN=your-bot-token
DISCORD_GUILD_ID=your-guild-id
DISCORD_ROLE_ID=your-role-id
DISCORD_WEBHOOK_URL=your-webhook-url

# --- Seguranca Interna ---------------------------------------
# [REQUIRED] Secret forte pra autenticar webhooks internos.
INTERNAL_WEBHOOK_SECRET=your-strong-random-secret-here

# --- Node ----------------------------------------------------
NODE_ENV=development
