generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/// Usuario da Oris Cloud. Gerenciado 100 por cento pelo better-auth.
/// As colunas no banco usam snake_case (padrao better-auth migrations),
/// entao mapeamos camelCase do Prisma Client para snake_case do Postgres.
model user {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false) @map("email_verified")
  image         String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at")
  session       session[]
  account       account[]
}

/// Sessao ativa do usuario (cookie httpOnly gerenciado pelo better-auth).
model session {
  id        String   @id
  expiresAt DateTime @map("expires_at")
  token     String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @updatedAt @map("updated_at")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  userId    String   @map("user_id")
  user      user     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Account liga um provider de autenticacao (email, Google, etc) ao user.
/// Para email+senha local, password e armazenado com hash bcrypt pelo better-auth.
/// Para OAuth, guarda access_token, refresh_token, id_token e os respectivos expires_at.
model account {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at")
  user                  user      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Modelo nativo do better-auth para armazenar tokens de verificacao
/// de email e reset de senha. Substituiu o modelo custom EmailVerification
/// (que armazenava codigos OTP) quando migramos pro fluxo de link magico.
/// Ver src/lib/auth.ts para os callbacks que geram estes registros.
model verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")
}

model Plan {
  id          String   @id @default(cuid())
  name        String   @unique
  price       Float
  duration    String
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model VCpuPlan {
  id          String   @id @default(cuid())
  name        String
  vCpus       Int
  ramGB       Int
  duration    String
  days        Int
  price       Float
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([vCpus, days])
  @@map("vcpu_plans")
}

model Stock {
  id          String   @id @default(cuid())
  total       Int
  available   Int
  reserved    Int      @default(0)
  updatedAt   DateTime @updatedAt
}

model Payment {
  id              String   @id @default(cuid())
  customId        String   @unique
  txid            String   @unique
  email           String
  plan            String
  amount          Float
  diskAddonId     String?
  diskSizeGB      Int      @default(256)
  vCpuPlanId      String?
  vCpus           Int      @default(4)
  ramGB           Int      @default(28)
  status          String   @default("pending")
  qrCodeBase64    String?  @db.Text
  pixCopiaECola   String?  @db.Text
  loc             String?
  webhookSended   Boolean  @default(false)
  discordId       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([customId])
  @@index([txid])
  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model DiskAddon {
  id          String   @id @default(cuid())
  name        String   @unique
  sizeGB      Int
  price       Float
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("disk_addons")
}

model PurchaseToken {
  id          String    @id @default(cuid())
  token       String    @unique
  planId      String
  days        Int
  price       Float
  diskSizeGB  Int       @default(256)
  vCpus       Int       @default(4)
  ramGB       Int       @default(28)
  isRedeemed  Boolean   @default(false)
  redeemedAt  DateTime?
  redeemedBy  String?
  createdAt   DateTime  @default(now())
  expiresAt   DateTime
  txid        String    @unique

  @@index([token])
  @@index([txid])
  @@index([isRedeemed])
  @@index([expiresAt])
  @@map("purchase_tokens")
}

model Subscription {
  id          String    @id @default(cuid())
  userId      String
  userEmail   String
  planId      String
  planName    String
  days        Int
  status      String    @default("active")
  startDate   DateTime  @default(now())
  expiresAt   DateTime
  tokenId     String    @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([userEmail])
  @@index([status])
  @@index([userId, status])
  @@index([expiresAt])
  @@map("subscriptions")
}

model Disk {
  id          String   @id @default(cuid())
  name        String
  awsVolumeId String?
  userId      String
  validUntil  DateTime
  isActive    Boolean  @default(true)
  vCpus       Int      @default(4)
  sizeGB      Int      @default(256)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
  @@index([userId])
  @@index([userId, isActive])
  @@index([isActive])
  @@map("disks")
}
