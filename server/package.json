{
  "name": "oris-cloud-backend",
  "version": "1.0.0",
  "description": "Backend Express + TypeScript para Oris Cloud - Plataforma de Cloud Gaming",
  "main": "dist/main.js",
  "type": "module",
  "scripts": {
    "start": "node dist/scripts/migrate.js && node dist/main.js",
    "start:dev": "tsx watch src/main.ts",
    "build": "tsc",
    "dev": "tsx watch src/main.ts",
    "typecheck": "tsc --noEmit",
    "db:migrate": "tsx src/scripts/migrate.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push"
  },
  "keywords": [
    "express",
    "typescript",
    "cloud-gaming",
    "api",
    "rest"
  ],
  "author": "Oris Cloud",
  "license": "MIT",
  "dependencies": {
    "better-auth": "^1.6.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "pg": "^8.11.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.20.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
